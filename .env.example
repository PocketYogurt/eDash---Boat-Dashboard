# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Google Maps ──────────────────────────────────────────────────────────────
# Enable "Maps JavaScript API" and "Places API (New)" in Google Cloud Console.
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── UKHO Admiralty Tidal API (Discovery tier — free) ─────────────────────────
# Sign up at https://developer.admiralty.co.uk, subscribe to UK Tidal API Discovery.
ADMIRALTY_API_KEY=your_admiralty_key_here

# ── AIS Vessel Tracking (optional) ────────────────────────────────────────────
# Sign up at https://aisstream.io for a free API key.
AISSTREAM_API_KEY=your_aisstream_key_here

# ── Admin Account ─────────────────────────────────────────────────────────────
# Created automatically on first boot if no users exist.
# Change the password immediately after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
